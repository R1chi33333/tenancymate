{
  "name": "tenancymate",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "pipeline": "node --no-warnings pipeline/run.ts",
    "pipeline:embed": "node --no-warnings --env-file=.env.local pipeline/embed.ts",
    "eval": "tsx --env-file=.env.local eval/run.ts",
    "eval:citations": "tsx --env-file=.env.local eval/citations.ts"
  },
  "dependencies": {
    "@ai-sdk/groq": "^4.0.5",
    "@huggingface/transformers": "^4.2.0",
    "@neondatabase/serverless": "^1.1.0",
    "ai": "^7.0.15",
    "lucide-react": "^1.23.0",
    "next": "15.5.20",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "prettier": "^3.9.4",
    "semantic-release": "^24.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "license": "MIT",
  "type": "module"
}
